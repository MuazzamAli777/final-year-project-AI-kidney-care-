import { useState, useRef, useEffect } from "react";
import conf from "../conf/conf.js";
import Header from "../homepagecomponets/header";
export default function Chatbot() {
  const [messages, setMessages] = useState([
    {
      id: "1",
      text: "Assalam o Alaikum! Main aapki kaise madad kar sakta hoon?",
      sender: "bot",
      timestamp: new Date(),
    },
  ]);

  const [inputValue, setInputValue] = useState("");
  const [loading, setLoading] = useState(false);

  const messagesEndRef = useRef(null);

  const API_KEY = conf.apikey;

const keywords = [
  // Basic
  "kidney", "kidneys", "renal", "nephro", "nephrology", "nephrologist",
  "urinary", "urine", "ureter", "bladder", "urethra",

  // Common misspellings (VERY IMPORTANT)
  "kideny", "kidny", "kidne", "kidnei", "kidneey", "kidni",
  "kidey", "kidnye", "kidneye", "kidnei", "kideneys",

  // Disease / Conditions
  "kidney disease", "kidney failure", "renal failure", "chronic kidney disease",
  "acute kidney injury", "ckd", "esrd", "end stage renal disease",
  "kidney infection", "pyelonephritis", "glomerulonephritis",
  "nephritis", "polycystic kidney disease", "pkd",

  // Stones
  "kidney stone", "kidney stones", "renal stone", "renal stones",
